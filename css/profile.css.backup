/* Profile Page Styles */
.main-content {
  min-height: calc(100vh - 70px);
  padding-top: 20px;
}

/* Profile Header */
.profile-header {
  display: flex;
  align-items: center;
  gap: 32px;
  margin-bottom: 40px;
  padding: 40px;
  background: linear-gradient(135deg, rgba(39, 179, 138, 0.1) 0%, rgba(52, 211, 153, 0.05) 100%);
  border-radius: var(--border-radius);
  border: 1px solid rgba(39, 179, 138, 0.2);
}

.profile-avatar {
  position: relative;
  flex-shrink: 0;
}

.avatar-placeholder {
  width: 120px;
  height: 120px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary), #34d399);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48px;
  font-weight: 700;
  color: white;
  border: 4px solid var(--surface);
  box-shadow: 0 8px 32px rgba(39, 179, 138, 0.3);
}

.avatar-upload {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: var(--primary);
  border: 3px solid var(--surface);
  color: white;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.avatar-upload:hover {
  background: var(--primary-600);
  transform: scale(1.1);
}

.profile-info {
  flex: 1;
}

.profile-info h1 {
  font-size: 32px;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 8px;
}

.profile-info p {
  color: var(--muted);
  font-size: 16px;
  margin-bottom: 24px;
}

.profile-stats {
  display: flex;
  gap: 32px;
}

.stat {
  text-align: center;
}

.stat-number {
  display: block;
  font-size: 24px;
  font-weight: 700;
  color: var(--primary);
  margin-bottom: 4px;
}

.stat-label {
  color: var(--muted);
  font-size: 12px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

/* Profile Tabs */
.profile-tabs {
  margin-bottom: 40px;
}

.tab-nav {
  display: flex;
  gap: 8px;
  margin-bottom: 32px;
  background: var(--surface);
  border: 1px solid var(--ring);
  border-radius: var(--border-radius);
  padding: 8px;
}

.tab-btn {
  flex: 1;
  padding: 12px 20px;
  background: transparent;
  border: none;
  color: var(--muted);
  font-weight: 500;
  border-radius: var(--border-radius-sm);
  cursor: pointer;
  transition: all 0.3s ease;
  text-align: center;
}

.tab-btn:hover {
  color: var(--text);
  background: rgba(39, 179, 138, 0.1);
}

.tab-btn.active {
  color: var(--text);
  background: var(--primary);
}

.tab-content {
  display: none;
}

.tab-content.active {
  display: block;
  animation: fadeIn 0.3s ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}

/* Profile Card */
.profile-card {
  background: var(--surface);
  border: 1px solid var(--ring);
  border-radius: var(--border-radius);
  padding: 32px;
  box-shadow: var(--shadow);
}

.profile-card h3 {
  font-size: 24px;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 24px;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24px;
}

.card-header h3 {
  margin-bottom: 0;
}

/* Profile Form */
.profile-form {
  display: flex;
  flex-direction: column;
  gap: 24px;
}

.form-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
}

.form-group {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.form-group label {
  color: var(--muted);
  font-size: 14px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.form-group input,
.form-group textarea {
  background: #f8f9fa;
  color: var(--text);
  border: 1px solid var(--ring);
  border-radius: var(--border-radius-sm);
  padding: 12px 16px;
  font-size: 14px;
  transition: all 0.3s ease;
}

.form-group input:focus,
.form-group textarea:focus {
  outline: none;
  border-color: var(--primary);
  box-shadow: 0 0 0 3px rgba(39, 179, 138, 0.1);
  transform: translateY(-1px);
}

.form-group input:disabled {
  background: var(--ring);
  color: var(--muted);
  cursor: not-allowed;
}

.form-help {
  color: var(--muted);
  font-size: 12px;
  margin-top: 4px;
}

.form-actions {
  display: flex;
  gap: 12px;
  justify-content: flex-end;
  margin-top: 8px;
}

/* Properties Grid */
.properties-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 20px;
}

/* Settings */
.settings-section {
  margin-bottom: 32px;
  padding-bottom: 24px;
  border-bottom: 1px solid var(--ring);
}

.settings-section:last-child {
  border-bottom: none;
  margin-bottom: 0;
}

.settings-section h4 {
  font-size: 18px;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 16px;
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 0;
  border-bottom: 1px solid rgba(42, 60, 70, 0.3);
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-info {
  flex: 1;
}

.setting-info label {
  display: block;
  font-weight: 500;
  color: var(--text);
  margin-bottom: 4px;
}

.setting-info p {
  color: var(--muted);
  font-size: 14px;
  margin: 0;
}

.setting-control {
  background: #f8f9fa;
  color: var(--text);
  border: 1px solid var(--ring);
  border-radius: var(--border-radius-sm);
  padding: 8px 12px;
  font-size: 14px;
}

/* Toggle Switch */
.toggle-switch {
  position: relative;
  display: inline-block;
  width: 50px;
  height: 24px;
}

.toggle-switch input {
  opacity: 0;
  width: 0;
  height: 0;
}

.toggle-slider {
  position: absolute;
  cursor: pointer;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: var(--ring);
  transition: 0.3s;
  border-radius: 24px;
}

.toggle-slider:before {
  position: absolute;
  content: "";
  height: 18px;
  width: 18px;
  left: 3px;
  bottom: 3px;
  background-color: white;
  transition: 0.3s;
  border-radius: 50%;
}

input:checked + .toggle-slider {
  background-color: var(--primary);
}

input:checked + .toggle-slider:before {
  transform: translateX(26px);
}

/* Danger Zone */
.danger-zone {
  border-color: var(--danger) !important;
}

.danger-zone h4 {
  color: var(--danger);
}

/* Empty States */
.empty-state {
  text-align: center;
  padding: 60px 20px;
  color: var(--muted);
}

.empty-state h3 {
  font-size: 20px;
  margin-bottom: 12px;
  color: var(--text);
}

.empty-state p {
  font-size: 14px;
  margin-bottom: 20px;
}

/* Loading States */
.loading-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 20px;
}

.loading-card {
  background: var(--surface);
  border: 1px solid var(--ring);
  border-radius: var(--border-radius);
  padding: 20px;
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

/* Responsive Design */
@media (max-width: 1024px) {
  .profile-header {
    flex-direction: column;
    text-align: center;
    gap: 24px;
  }
  
  .profile-stats {
    justify-content: center;
  }
  
  .form-row {
    grid-template-columns: 1fr;
  }
  
  .properties-grid {
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  }
}

@media (max-width: 768px) {
  .main-content {
    padding-top: 10px;
  }
  
  .profile-header {
    padding: 24px;
  }
  
  .profile-info h1 {
    font-size: 24px;
  }
  
  .profile-stats {
    flex-direction: column;
    gap: 16px;
  }
  
  .tab-nav {
    flex-direction: column;
  }
  
  .tab-btn {
    text-align: left;
  }
  
  .profile-card {
    padding: 24px;
  }
  
  .properties-grid {
    grid-template-columns: 1fr;
  }
  
  .setting-item {
    flex-direction: column;
    align-items: flex-start;
    gap: 12px;
  }
  
  .form-actions {
    flex-direction: column;
  }
}

@media (max-width: 480px) {
  .profile-header {
    padding: 20px;
  }
  
  .profile-info h1 {
    font-size: 20px;
  }
  
  .profile-card {
    padding: 20px;
  }
  
  .avatar-placeholder {
    width: 100px;
    height: 100px;
    font-size: 40px;
  }
  
  .avatar-upload {
    width: 32px;
    height: 32px;
  }
}

/* Animations */
.profile-header {
  animation: slideInUp 0.6s ease-out;
}

@keyframes slideInUp {
  from {
    opacity: 0;
    transform: translateY(30px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* Success/Error States */
.form-group.success input,
.form-group.success textarea {
  border-color: var(--success);
  box-shadow: 0 0 0 3px rgba(39, 179, 138, 0.1);
}

.form-group.error input,
.form-group.error textarea {
  border-color: var(--danger);
  box-shadow: 0 0 0 3px rgba(229, 83, 75, 0.1);
}

.error-message {
  color: var(--danger);
  font-size: 12px;
  margin-top: 4px;
}

.success-message {
  color: var(--success);
  font-size: 12px;
  margin-top: 4px;
}

/* Button States */
.btn:disabled {
  opacity: 0.6;
  cursor: not-allowed;
  transform: none !important;
}

.btn:disabled:hover {
  transform: none !important;
}

/* Focus Management */
.tab-btn:focus,
.setting-control:focus,
.toggle-switch:focus {
  outline: 2px solid var(--primary);
  outline-offset: 2px;
}
